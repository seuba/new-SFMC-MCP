{
  "name": "sfmc-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Salesforce Marketing Cloud — Data Extensions, Email Sends, Subscribers, Journey Builder, and CloudPages.",
  "type": "module",
  "bin": {
    "sfmc-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
